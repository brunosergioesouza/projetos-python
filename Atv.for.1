#Exercício 6

try:
    lista = [1, 2, 3, 4]
    soma = 0

    for n in lista:
        soma += n

    print("A soma é", soma)

except Exception as e:
    print("Ocorreu um erro:", e)

#Exercício 7

try:
    notas = [7,8,9,5]
    soma = sum(notas)
    media = soma / len(lista)
    print("A média é:", media)

except ZeroDivisionError:
    print("Erro: a lista está vazia, não é possível calcular a média.")


